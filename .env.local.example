# ============================================================
# kol-mail-desk-v2-web · 前端环境变量模板
# ------------------------------------------------------------
# 用法：
#   cp .env.local.example .env.local
#
# 真正的 .env.local 已在 .gitignore 中，永远不要 commit。
# 字段权威列表见 ../kol-mail-desk-v2-docs/specs/SETUP.md § 4.2
# ============================================================

# 后端 API base URL（本地默认指向 docker compose 启的后端 dev 服务）
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# 应用展示名（用户可见，中文）
NEXT_PUBLIC_APP_NAME=Lovart Mail Desk
